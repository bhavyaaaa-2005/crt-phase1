// problem -- 1
// print 1 to 10,10 numbr of times

#include <iostream>
using namespace std;
int main()
{
    // number of times to print the pattern
    for(int i = 1; i <= 10; i++) {
        // this defines what to print in the pattern
        for(int j = 1; j <= 10; j++){
            cout << j << "";
        }
        cout << "\n";
    }
    return 0;
}


