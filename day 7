// access specifier
// 7.3 -- protected

#include <iostream>
using namespace std; 
class Parent {
 protected:   
    int secretCode = 1234;
    
};
class child : public Parent{
    public:
   void accessOfSecretCode() {
        cout << "Secret of the locker is" << secretCode;
}
};
int main() {
    child obj1;
    obj1.accessOfSecretCode();
}


// problem -- 3
// pillar of OOPS
// encapsulation
// encapsulation means we are binding the data into a single unit ( function, data, variables, methods)
// into a single unit called class and making some restrictions on this class members
// data security
// controlled access over my data
// validation before accessing the data
// code maintainability

#include <iostream>
using namespace std; 

class bankAccount{
    private:
    int balance;
    
    public:

 void setBalance(int amount) {
     if(amount >= 0) {
         balance = amount;
     } else {
         cout <<"Enter a valid number...";
     }
 }   
public:
    int getbalance() {
       return balance;
    }
};
int main() {
    bankAccount obj1;
    obj1.setBalance(5000);
    cout << obj1.getbalance();
}
