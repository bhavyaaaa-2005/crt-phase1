class Vehicle {
public:
   void start() {
       cout << "Vehicle starts" <<"\n";
   }
 };
 class Bike : public Vehicle {
 public:
     void drive(){
         cout << "Bike is running" << "\n";
     }
 };

 class Car : public Vehicle {
 public:
     void chalna() {
         cout << "Car is challing" << "\n";
     }
 };
 int main() {
     Car obj1;
     Bike obj2;
    
     obj1.chalna();
     obj1.start();
    
     obj2.start();
