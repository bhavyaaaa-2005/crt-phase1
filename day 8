// inheritance
// types -- 1.1 single inheritance

#include <iostream>
using namespace std;

class vehicle {
    public:
    void start() {
        cout << "vehicle starts" << "\n";
    }
};

class car :public vehicle {
    public:
    void drive() {
        cout << "car is running" << "\n";
    }
};

int main() {
    car obj1;
    obj1.drive();
    obj1.start();
    
    return 0;
}
