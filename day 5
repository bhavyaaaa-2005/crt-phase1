PROBLEM 01: DIAMOND HALF-PATTERN 🔼🔽
Task: Combine upper and lower triangles
Pattern:
*
**
***
**
*

#include <iostream>
using namespace std;
int main() {
    for(int i = 1; i <= 5; i++) {
       for(int j = 1;  j<= i; j++){ cout << "*"; }
       cout <<"\n";
   }
for(int k = 5-1; k >= 1; k--) {
       for(int l = 1; l <= k; l++){ cout << "*"; }
       cout <<"\n";
   }
    return 0;
}



